<Window x:Class="Mushub.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Mushub.Views"
        Title="Mushub"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border with rounded corners -->
    <Border CornerRadius="14" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF1A1A2E" Offset="0"/>
                <GradientStop Color="#FF16213E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <!-- Title bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <!-- Side nav -->
                <ColumnDefinition Width="*"/>
                <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════
                 TITLE BAR
                 ═══════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#CC1A1A2E"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🍄" FontSize="20"/>
                    </StackPanel>

                    <!-- Title -->
                    <TextBlock Grid.Column="1"
                               Text="Mushub"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="MinimizeButton" Style="{StaticResource IconButton}"
                                Width="40" Height="32"
                                Click="MinimizeButton_Click">
                            <TextBlock Text="─" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource IconButton}"
                                Width="40" Height="32"
                                Click="MaximizeButton_Click">
                            <TextBlock Text="□" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                        <!-- CloseButton: style défini une seule fois via Button.Style, sans attribut Style en doublon -->
                        <Button x:Name="CloseButton"
                                Width="40" Height="32"
                                Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════
                 SIDE NAVIGATION
                 ═══════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="#881A1A2E"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top" Margin="0,12,0,0">

                    <RadioButton x:Name="NavHome" Style="{StaticResource NavTabButton}"
                                 GroupName="Navigation" IsChecked="True"
                                 Click="NavHome_Click"
                                 ToolTip="Accueil · Todo List">
                        <StackPanel>
                            <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Accueil" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavPomodoro" Style="{StaticResource NavTabButton}"
                                 GroupName="Navigation" Margin="0,4,0,0"
                                 Click="NavPomodoro_Click"
                                 ToolTip="Pomodoro Timer">
                        <StackPanel>
                            <TextBlock Text="🍅" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pomodoro" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavHub" Style="{StaticResource NavTabButton}"
                                 GroupName="Navigation" Margin="0,4,0,0"
                                 Click="NavHub_Click"
                                 ToolTip="Mini-Hub · Raccourcis">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Mini-Hub" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavTabButton}"
                                 GroupName="Navigation" Margin="0,4,0,0"
                                 Click="NavSettings_Click"
                                 ToolTip="Paramètres">
                        <StackPanel>
                            <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Config" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════
                 MAIN CONTENT AREA
                 ═══════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="1">
                <!-- Pages (only one visible at a time) -->
                <views:TodoPage x:Name="TodoPageView" Visibility="Visible"/>
                <views:PomodoroPage x:Name="PomodoroPageView" Visibility="Collapsed"/>
                <views:HubPage x:Name="HubPageView" Visibility="Collapsed"/>
                <views:SettingsPage x:Name="SettingsPageView" Visibility="Collapsed"/>
            </Grid>

            <!-- Resize grip -->
            <ResizeGrip Grid.Row="1" Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Foreground="{StaticResource TextMutedBrush}"
                        Width="16" Height="16"/>
        </Grid>
    </Border>
</Window>
