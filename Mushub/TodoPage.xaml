<UserControl x:Class="Mushub.Views.TodoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Add task -->
            <RowDefinition Height="*"/>
            <!-- Task list -->
            <RowDefinition Height="Auto"/>
            <!-- Footer stats -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER — Greeting
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="28,24,28,16" Padding="24,20" CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#221A1A2E" Offset="0"/>
                    <GradientStop Color="#447C4DFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#447C4DFF" Offset="0"/>
                    <GradientStop Color="#22C678DD" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="GreetingText"
                               Text="Bonne journée !"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="GreetingSubtext"
                               Text="Que faisons-nous aujourd'hui ?"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock x:Name="DateText"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11" Margin="0,6,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="GreetingEmoji"
                           Text="☀️"
                           FontSize="40"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             ADD TASK
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="28,0,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NewTaskInput"
                         Grid.Column="0"
                         Style="{StaticResource Win11TextBox}"
                         Height="44"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         KeyDown="NewTaskInput_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10,0,0,10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Priority selector -->
                <ComboBox x:Name="PriorityCombo"
                          Grid.Column="1"
                          Width="110"
                          Height="44"
                          Background="{StaticResource Surface3Brush}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush2}"
                          BorderThickness="0,1,1,1"
                          VerticalContentAlignment="Center"
                          Margin="0">
                    <ComboBoxItem Content="🔵 Normale" IsSelected="True"/>
                    <ComboBoxItem Content="🟠 Haute"/>
                    <ComboBoxItem Content="🔴 Urgente"/>
                    <ComboBoxItem Content="🟢 Basse"/>
                </ComboBox>

                <Button Grid.Column="2"
                        Style="{StaticResource AccentButton}"
                        Height="44"
                        Padding="16,0"
                        Click="AddTask_Click"
                        Margin="0">
                    <TextBlock Text="＋ Ajouter" FontSize="13" FontWeight="SemiBold"/>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,10,10,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             TASK LIST
             ═══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" Margin="28,0,28,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource Win11ScrollViewer}">
            <StackPanel x:Name="TaskPanel">
                <!-- Tasks are added here dynamically -->
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════
             FOOTER STATS
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="3" Margin="28,0,28,16" Padding="16,10"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="SyncStatusText"
                           Text="● Synchronisé"
                           Foreground="{StaticResource SuccessBrush}"
                           FontSize="12" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           x:Name="TotalTasksText"
                           Text="0 tâches"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="2"
                           x:Name="DoneTasksText"
                           Text="0 terminées"
                           Foreground="{StaticResource SuccessBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Button Grid.Column="3" Style="{StaticResource IconButton}"
                        Click="ClearCompleted_Click"
                        ToolTip="Supprimer les tâches terminées">
                    <TextBlock Text="🗑️ Nettoyer" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
