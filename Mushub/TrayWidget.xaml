<Window x:Class="Mushub.Views.TrayWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mushub Widget"
        Width="320" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#EE1A1A2E" Offset="0"/>
                <GradientStop Color="#EE16213E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="8" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Grid -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#221A1A2E"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0">
                        <TextBlock Text="🍄" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Mushub Widget"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,0"
                            Width="28" Height="28"
                            Click="CloseWidget_Click">
                        <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Stream Deck Grid -->
            <ScrollViewer Grid.Row="1" Margin="10,8,10,8"
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource Win11ScrollViewer}">
                <UniformGrid x:Name="WidgetGrid" Columns="3"/>
            </ScrollViewer>

            <!-- Footer: quick Pomodoro info -->
            <Border Grid.Row="2"
                    Background="#221A1A2E"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="0,1,0,0"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="WidgetClock"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="11"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OpenMainApp_Click"
                            ToolTip="Ouvrir Mushub">
                        <TextBlock Text="↗ Ouvrir" FontSize="10"
                                   Foreground="{StaticResource AccentLightBrush}"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
