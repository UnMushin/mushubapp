<Window x:Class="MushubUpdater.UpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mushub Updater"
        Width="560" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <!-- Terminal dark background -->
        <Border.Background>
            <SolidColorBrush Color="#FF0D1117"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="6" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <!-- Title bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="52"/>
                <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════ TERMINAL TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="#FF161B22"
                    MouseLeftButtonDown="TitleBar_DragMove">
                <Grid>
                    <!-- macOS-style dots -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Ellipse Width="12" Height="12" Fill="#FFFF5F57" Margin="0,0,6,0"/>
                        <Ellipse Width="12" Height="12" Fill="#FFFFBD2F" Margin="0,0,6,0"/>
                        <Ellipse Width="12" Height="12" Fill="#FF28CA41"/>
                    </StackPanel>

                    <!-- Title -->
                    <TextBlock Text="mushub-updater — vérification des mises à jour"
                               Foreground="#FF8B949E"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════ TERMINAL CONTENT ═══════════ -->
            <Border Grid.Row="1" Background="#FF0D1117" Padding="16,12">
                <ScrollViewer x:Name="LogScroll"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LogPanel">

                        <!-- ASCII art header -->
                        <TextBlock FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   Foreground="#FF7C4DFF"
                                   Margin="0,0,0,8"
                                   xml:space="preserve">  __  __           _     _           _
 |  \/  |         | |   | |         | |
 | \  / |_   _ ___| |__ | |__  _   _| |__
 | |\/| | | | / __| '_ \| '_ \| | | | '_ \
 | |  | | |_| \__ \ | | | | | | |_| | |_) |
 |_|  |_|\__,_|___/_| |_|_| |_|\__,_|_.__/
                              ~ updater v1.0 ~</TextBlock>

                        <TextBlock x:Name="LogOutput"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="12"
                                   Foreground="#FFC9D1D9"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══════════ ACTION BAR ═══════════ -->
            <Border Grid.Row="2" Background="#FF161B22"
                    BorderBrush="#FF30363D" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Initialisation..."
                               Foreground="#FF8B949E"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <Button x:Name="ActionButton"
                            Grid.Column="1"
                            Visibility="Collapsed"
                            Click="ActionButton_Click"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF7C4DFF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFB47AFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="CloseButton"
                            Grid.Column="2"
                            Content="Fermer"
                            Click="CloseButton_Click"
                            Visibility="Collapsed">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF21262D"/>
                                <Setter Property="Foreground" Value="#FF8B949E"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#FF30363D"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
